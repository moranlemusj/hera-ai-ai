# =============================================================================
# Hera Agent — environment template
# Copy to .env and fill in. Never commit your real .env.
# =============================================================================

# --- Neon Postgres -----------------------------------------------------------
# Create a project at console.neon.tech, copy the pooled connection string.
# Required extensions: vector, pg_trgm (run in Neon SQL editor):
#   CREATE EXTENSION IF NOT EXISTS vector;
#   CREATE EXTENSION IF NOT EXISTS pg_trgm;
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# --- Hera public REST API (x-api-key) ----------------------------------------
# Request a key from Hera (enterprise / early access).
HERA_API_KEY=

# --- Google AI Studio (Gemini) -----------------------------------------------
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Hera dashboard session (cookie auth) is NOT here.
# It lives in the `app_secrets` table on Neon and is set via the UI:
#   Settings → Hera Session → Update from cURL
# -----------------------------------------------------------------------------
